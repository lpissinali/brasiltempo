# Public site URL (used for canonical/OG metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- AI (Zé do Tempo phrase generation) — not wired yet ---
# When you enable live phrase generation, set this and switch the stub in
# src/lib/phrases.ts to call Anthropic Haiku.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Data source ---
# NOAA GFS via PacIOOS ERDDAP (public domain, commercial use allowed, no key).
# Override only if you mirror ERDDAP or change datasets.
ERDDAP_BASE=https://pae-paha.pacioos.hawaii.edu/erddap
GFS_DATASET=ncep_global

# --- Geocoding (worldwide city search) ---
# Default provider is Open-Meteo geocoding (no key, great pt-BR names).
# NOTE: Open-Meteo's free tier is non-commercial — same caveat as their weather.
# For commercial use, create a free GeoNames account (CC-BY) and set the
# username below; src/lib/geocode.ts switches to GeoNames automatically.
# GEONAMES_USERNAME=your_geonames_user
