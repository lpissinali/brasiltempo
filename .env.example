# Public site URL (used for canonical/OG metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- AI (Zé do Tempo phrase generation) ---
# Zé's lines are generated by Anthropic Haiku in a batch (one call per scope per
# day), cached in Firestore, with the static pools in src/lib/phrases.ts as the
# always-on fallback. Leave ANTHROPIC_API_KEY UNSET and the app uses the static
# pools exactly as before — no AI calls, no cost.
# ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (defaults to claude-haiku-4-5-20251001):
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Shared secret protecting the optional pre-warm route /api/cron/phrases:
# CRON_SECRET=some-long-random-string

# --- Data source ---
# NOAA GFS via PacIOOS ERDDAP (public domain, commercial use allowed, no key).
# Override only if you mirror ERDDAP or change datasets.
ERDDAP_BASE=https://pae-paha.pacioos.hawaii.edu/erddap
GFS_DATASET=ncep_global

# --- Firestore cache (L2, shared across instances) ---
# In production on Firebase App Hosting, credentials and the project id are
# provided automatically (GCLOUD_PROJECT + the backend service account's ADC),
# so you do NOT need to set anything here for deploy.
# Locally there are no credentials, so the Firestore layer auto-disables and the
# app falls back to the in-memory cache + live ERDDAP fetch — dev works with no
# Firebase setup. To test against real Firestore locally, point this at a service
# account key (GOOGLE_APPLICATION_CREDENTIALS=/path/key.json) and set the id below.
# FIREBASE_PROJECT_ID=brasiltempo-75a7a
# Force-disable the Firestore layer even when credentials exist:
# FIRESTORE_DISABLED=1

# --- Geocoding (worldwide city search) ---
# Default provider is Open-Meteo geocoding (no key, great pt-BR names).
# NOTE: Open-Meteo's free tier is non-commercial — same caveat as their weather.
# For commercial use, create a free GeoNames account (CC-BY) and set the
# username below; src/lib/geocode.ts switches to GeoNames automatically.
# GEONAMES_USERNAME=your_geonames_user
